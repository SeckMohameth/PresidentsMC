EXPO_PUBLIC_CLUB_ID=presidents-mc
EXPO_PUBLIC_CLUB_NAME=PresidentsMC
EXPO_PUBLIC_CLUB_DESCRIPTION=Private biker club rides, announcements, members, photos, and stats.
EXPO_PUBLIC_OWNER_EMAILS=owner@example.com
EXPO_PUBLIC_DEVELOPER_ADMIN_EMAILS=developer@example.com

EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id
# PresidentsMC currently uses a named Firestore database created in Firebase Console.
# Use default for presidentsmc-50010, or omit this if your project uses (default).
EXPO_PUBLIC_FIRESTORE_DATABASE_ID=default
EXPO_PUBLIC_EAS_PROJECT_ID=

EXPO_PUBLIC_ENABLE_REVENUECAT=true
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=test_yCWPzNoPOGccAdoqidlUuuERyxa
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=test_yCWPzNoPOGccAdoqidlUuuERyxa
EXPO_PUBLIC_REVENUECAT_TEST_API_KEY=test_yCWPzNoPOGccAdoqidlUuuERyxa
EXPO_PUBLIC_TESTFLIGHT_CREW_ADMIN_BYPASS=false
# Billing is disabled by default in the app data model through crew.billingRequired=false.
# Add RevenueCat keys only when you are ready to enable paid admin access.

# Required for Android production/dev builds that render react-native-maps.
# Restrict this key to app.mostudios.presidentsmc and your Android signing SHA-1 in Google Cloud.
GOOGLE_MAPS_ANDROID_API_KEY=

# Optional only if you switch iOS MapView to Google provider instead of Apple Maps.
GOOGLE_MAPS_IOS_API_KEY=
