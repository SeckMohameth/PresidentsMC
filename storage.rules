rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isPresidentsClub(crewId) {
      return crewId == 'presidents-mc';
    }

    function crewDoc(crewId) {
      return firestore.get(/databases/default/documents/crews/$(crewId));
    }

    function crewMemberDoc(crewId, userId) {
      return firestore.get(/databases/default/documents/crews/$(crewId)/members/$(userId));
    }

    function isCrewMember(crewId) {
      return signedIn()
        && isPresidentsClub(crewId)
        && firestore.exists(/databases/default/documents/crews/$(crewId)/members/$(request.auth.uid));
    }

    function isCrewOwner(crewId) {
      return isCrewMember(crewId) && crewDoc(crewId).data.ownerId == request.auth.uid;
    }

    function isCrewLeader(crewId) {
      return isCrewMember(crewId)
        && ['admin', 'officer'].hasAny([crewMemberDoc(crewId, request.auth.uid).data.role]);
    }

    function memberPermission(crewId, key) {
      return isCrewMember(crewId)
        && crewMemberDoc(crewId, request.auth.uid).data.permissions[key] == true;
    }

    function hasActiveSubscription(crewId) {
      return ['active', 'trialing'].hasAny([crewDoc(crewId).data.subscriptionStatus]);
    }

    function canUseAdminTools(crewId) {
      return isDeveloperSupport(crewId)
        || isCrewOwner(crewId)
        || (
          isCrewLeader(crewId)
          && (crewDoc(crewId).data.billingRequired != true || hasActiveSubscription(crewId))
        );
    }

    function canManageCrewSettings(crewId) {
      return isDeveloperSupport(crewId)
        || isCrewOwner(crewId)
        || (
          isCrewMember(crewId)
          && crewMemberDoc(crewId, request.auth.uid).data.role == 'admin'
          && (crewDoc(crewId).data.billingRequired != true || hasActiveSubscription(crewId))
        );
    }

    function canUseDelegatedTool(crewId, key) {
      return canUseAdminTools(crewId)
        || (
          memberPermission(crewId, key)
          && (crewDoc(crewId).data.billingRequired != true || hasActiveSubscription(crewId))
        );
    }

    function isDeveloperSupport(crewId) {
      return isCrewMember(crewId)
        && crewMemberDoc(crewId, request.auth.uid).data.isDeveloperSupport == true;
    }

    function isImage() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /users/{userId}/avatar.jpg {
      allow read: if isSelf(userId);
      allow write: if isSelf(userId) && isImage();
    }

    match /crews/{crewId}/logo.jpg {
      allow read: if isCrewMember(crewId);
      allow write: if canManageCrewSettings(crewId)
        && crewDoc(crewId).data.status == 'active'
        && isImage();
    }

    match /crews/{crewId}/announcements/{fileName} {
      allow read: if isCrewMember(crewId);
      allow write: if canUseDelegatedTool(crewId, 'manageAnnouncements')
        && isImage();
      allow delete: if canUseDelegatedTool(crewId, 'manageAnnouncements');
    }

    match /crews/{crewId}/rides/{rideId}/cover.jpg {
      allow read: if isCrewMember(crewId);
      allow write: if canUseDelegatedTool(crewId, 'manageRides')
        && isImage();
      allow delete: if canUseDelegatedTool(crewId, 'manageRides');
    }

    match /crews/{crewId}/rides/{rideId}/photos/{fileName} {
      allow read: if isCrewMember(crewId);
      allow write: if isCrewMember(crewId) && isImage();
      allow delete: if canUseAdminTools(crewId);
    }

    match /crews/{crewId}/albums/{albumId}/cover.jpg {
      allow read: if isCrewMember(crewId);
      allow write: if canUseDelegatedTool(crewId, 'manageAlbums')
        && isImage();
      allow delete: if canUseDelegatedTool(crewId, 'manageAlbums');
    }

    match /crews/{crewId}/albums/{albumId}/photos/{fileName} {
      allow read: if isCrewMember(crewId);
      allow write: if isCrewMember(crewId) && isImage();
      allow delete: if canUseAdminTools(crewId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
