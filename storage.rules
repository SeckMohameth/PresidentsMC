rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isPresidentsClub(crewId) {
      return crewId == 'presidents-mc';
    }

    function isDeveloperAdminEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email in [
          'mo@mostudios.io',
          'mostudiosdotio@gmail.com'
        ];
    }

    function isImage() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    function canReadCrewStorage(crewId) {
      return signedIn() && isPresidentsClub(crewId);
    }

    function canWriteCrewImage(crewId) {
      return signedIn() && isPresidentsClub(crewId) && isImage();
    }

    function canDeleteCrewImage(crewId) {
      return signedIn() && isPresidentsClub(crewId);
    }

    match /users/{userId}/avatar.jpg {
      allow read: if signedIn();
      allow write: if isSelf(userId) && isImage();
      allow delete: if isSelf(userId);
    }

    match /users/{userId}/bikes/{fileName} {
      allow read: if signedIn();
      allow write: if isSelf(userId) && isImage();
      allow delete: if isSelf(userId);
    }

    match /crews/{crewId}/logo.jpg {
      allow read: if canReadCrewStorage(crewId);
      allow write: if canWriteCrewImage(crewId);
      allow delete: if isDeveloperAdminEmail();
    }

    match /crews/{crewId}/announcements/{fileName} {
      allow read: if canReadCrewStorage(crewId);
      allow write: if canWriteCrewImage(crewId);
      allow delete: if canDeleteCrewImage(crewId);
    }

    match /crews/{crewId}/rides/{rideId}/cover.jpg {
      allow read: if canReadCrewStorage(crewId);
      allow write: if canWriteCrewImage(crewId);
      allow delete: if canDeleteCrewImage(crewId);
    }

    match /crews/{crewId}/rides/{rideId}/photos/{fileName} {
      allow read: if canReadCrewStorage(crewId);
      allow write: if canWriteCrewImage(crewId);
      allow delete: if canDeleteCrewImage(crewId);
    }

    match /crews/{crewId}/albums/{albumId}/cover.jpg {
      allow read: if canReadCrewStorage(crewId);
      allow write: if canWriteCrewImage(crewId);
      allow delete: if canDeleteCrewImage(crewId);
    }

    match /crews/{crewId}/albums/{albumId}/photos/{fileName} {
      allow read: if canReadCrewStorage(crewId);
      allow write: if canWriteCrewImage(crewId);
      allow delete: if canDeleteCrewImage(crewId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
