{
  "expo": {
    "name": "PresidentsMC",
    "slug": "presidentsmc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "presidentsmc",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.mostudios.presidentsmc",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Allow PresidentsMC to access your photos to upload ride photos and update your profile picture.",
        "NSCameraUsageDescription": "Allow PresidentsMC to use your camera for profile photos and ride photos.",
        "NSLocationWhenInUseUsageDescription": "Allow PresidentsMC to access your location for ride check-ins and route details.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#050505",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "app.mostudios.presidentsmc",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-notifications",
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#050505",
          "dark": {
            "backgroundColor": "#050505"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
