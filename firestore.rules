rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isPresidentsClub(crewId) {
      return crewId == 'presidents-mc';
    }

    function crewPath(crewId) {
      return /databases/$(database)/documents/crews/$(crewId);
    }

    function memberPath(crewId, userId) {
      return /databases/$(database)/documents/crews/$(crewId)/members/$(userId);
    }

    function crewDoc(crewId) {
      return get(crewPath(crewId));
    }

    function isCrewMember(crewId) {
      return signedIn() && exists(memberPath(crewId, request.auth.uid));
    }

    function memberRole(crewId) {
      return get(memberPath(crewId, request.auth.uid)).data.role;
    }

    function isCrewOwner(crewId) {
      return isCrewMember(crewId) && crewDoc(crewId).data.ownerId == request.auth.uid;
    }

    function isCrewLeader(crewId) {
      return isCrewMember(crewId) && ['admin', 'officer'].hasAny([memberRole(crewId)]);
    }

    function memberPermission(crewId, key) {
      return isCrewMember(crewId)
        && get(memberPath(crewId, request.auth.uid)).data.permissions[key] == true;
    }

    function isDeveloperSupport(crewId) {
      return isCrewMember(crewId)
        && get(memberPath(crewId, request.auth.uid)).data.isDeveloperSupport == true;
    }

    function hasActiveSubscription(crewId) {
      return ['active', 'trialing'].hasAny([crewDoc(crewId).data.subscriptionStatus]);
    }

    function canUseAdminTools(crewId) {
      return isDeveloperSupport(crewId)
        || (isPresidentsClub(crewId) && isDeveloperAdminEmail())
        || isCrewOwner(crewId)
        || (
          isCrewLeader(crewId)
          && (crewDoc(crewId).data.billingRequired != true || hasActiveSubscription(crewId))
        );
    }

    function canManageCrewSettings(crewId) {
      return isDeveloperSupport(crewId)
        || (isPresidentsClub(crewId) && isDeveloperAdminEmail())
        || isCrewOwner(crewId)
        || (
          isCrewMember(crewId)
          && memberRole(crewId) == 'admin'
          && (crewDoc(crewId).data.billingRequired != true || hasActiveSubscription(crewId))
        );
    }

    function canUseDelegatedTool(crewId, key) {
      return canUseAdminTools(crewId)
        || (
          memberPermission(crewId, key)
          && (crewDoc(crewId).data.billingRequired != true || hasActiveSubscription(crewId))
        );
    }

    function canReadCrewData(crewId) {
      return isPresidentsClub(crewId)
        && (isCrewMember(crewId) || isDeveloperAdminEmail());
    }

    function canManageJoinRequestsForPresidentsClub() {
      return canUseAdminTools('presidents-mc')
        || memberPermission('presidents-mc', 'manageJoinRequests');
    }

    function isDeveloperAdminEmail() {
      return signedIn()
        && request.auth.token.email != null
        && request.auth.token.email in [
          'mo@mostudios.io',
          'mostudiosdotio@gmail.com'
        ];
    }

    function isBootstrapOwnerProfile(data) {
      return data.id == request.auth.uid
        && !exists(crewPath('presidents-mc'))
        && data.crewId == 'presidents-mc'
        && data.role == 'admin'
        && data.pendingCrewId == null;
    }

    function isDeveloperAdminProfile(data) {
      return data.id == request.auth.uid
        && isDeveloperAdminEmail()
        && data.crewId == 'presidents-mc'
        && data.role == 'admin'
        && data.pendingCrewId == null;
    }

    function isDeveloperSupportMemberData(data) {
      return data.id == request.auth.uid
        && isDeveloperAdminEmail()
        && data.email == request.auth.token.email
        && data.role == 'admin'
        && data.isDeveloperSupport == true;
    }

    function validSelfCrewState(data) {
      return data.crewId == null
        ? data.role == 'member'
        : exists(memberPath(data.crewId, request.auth.uid))
          && get(memberPath(data.crewId, request.auth.uid)).data.role == data.role;
    }

    function validUserMutableKeys() {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly([
        'name',
        'email',
        'avatar',
        'bike',
        'bikes',
        'preferences',
        'hasOnboarded',
        'hasFeatureOnboarded',
        'lastActiveAt',
        'crewId',
        'role',
        'pendingCrewId'
      ]);
    }

    match /users/{userId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId)
        && request.resource.data.id == userId
        && (
          (
            request.resource.data.role == 'member'
            && request.resource.data.crewId == null
          )
          || isBootstrapOwnerProfile(request.resource.data)
          || isDeveloperAdminProfile(request.resource.data)
        );
      allow update: if isSelf(userId)
        && request.resource.data.id == userId
        && validUserMutableKeys()
        && (
          validSelfCrewState(request.resource.data)
          || isBootstrapOwnerProfile(request.resource.data)
          || isDeveloperAdminProfile(request.resource.data)
        )
        || (
          canManageJoinRequestsForPresidentsClub()
          && resource.data.pendingCrewId == 'presidents-mc'
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'crewId',
            'role',
            'pendingCrewId'
          ])
          && request.resource.data.crewId == 'presidents-mc'
          && request.resource.data.role == 'member'
          && request.resource.data.pendingCrewId == null
        )
        || (
          canManageJoinRequestsForPresidentsClub()
          && resource.data.pendingCrewId == 'presidents-mc'
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'pendingCrewId'
          ])
          && request.resource.data.pendingCrewId == null
        );
      allow delete: if false;

      match /pushTokens/{token} {
        allow read, create, update, delete: if isSelf(userId);
      }
    }

    match /crews/{crewId} {
      allow read: if canReadCrewData(crewId);
      allow create: if isPresidentsClub(crewId)
        && signedIn()
        && !exists(crewPath(crewId))
        && request.resource.data.id == crewId
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.subscriptionOwnerId == request.auth.uid
        && request.resource.data.memberCount == 1
        && request.resource.data.status == 'active'
        && request.resource.data.archivedAt == null
        && request.resource.data.purgeAt == null;
      allow update: if isPresidentsClub(crewId)
        && (
          (
            canManageCrewSettings(crewId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'name',
              'description',
              'logoUrl',
              'isDiscoverable',
              'requiresApproval',
              'billingRequired',
              'nameLower'
            ])
            && (
              !request.resource.data.diff(resource.data).changedKeys().hasAny(['billingRequired'])
              || isCrewOwner(crewId)
              || isDeveloperSupport(crewId)
              || isDeveloperAdminEmail()
            )
          )
          || (
            canManageJoinRequestsForPresidentsClub()
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['memberCount'])
            && request.resource.data.memberCount == resource.data.memberCount + 1
          )
        );
      allow delete: if false;

      match /members/{memberId} {
        allow read: if canReadCrewData(crewId);
        allow create: if isPresidentsClub(crewId)
          && (
            (
              isSelf(memberId)
              && request.resource.data.id == request.auth.uid
              && request.resource.data.role == 'admin'
            )
            || (
              canManageJoinRequestsForPresidentsClub()
              && request.resource.data.id == memberId
              && request.resource.data.role == 'member'
              && request.resource.data.email is string
              && request.resource.data.name is string
            )
          )
          && (
            !exists(crewPath(crewId))
            || crewDoc(crewId).data.ownerId == request.auth.uid
            || canManageJoinRequestsForPresidentsClub()
            || (
              isDeveloperAdminEmail()
              && request.resource.data.email == request.auth.token.email
              && request.resource.data.isDeveloperSupport == true
            )
          );
        allow update: if isPresidentsClub(crewId)
          && isSelf(memberId)
          && isCrewMember(crewId)
          && (
            request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'name',
              'email',
              'avatar',
              'bike',
              'bikes'
            ])
            || (
              isDeveloperSupportMemberData(request.resource.data)
              && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'id',
                'name',
                'email',
                'avatar',
                'role',
                'isDeveloperSupport',
                'joinedCrewAt',
                'ridesAttended',
                'milesTraveled'
              ])
            )
          );
        allow delete: if false;
      }

      match /private/{docId} {
        allow read: if isPresidentsClub(crewId)
          && docId == 'settings'
          && canManageCrewSettings(crewId);
        allow create: if isPresidentsClub(crewId)
          && docId == 'settings'
          && canManageCrewSettings(crewId)
          && request.resource.data.keys().hasOnly(['inviteCode', 'expiresAt', 'updatedAt'])
          && request.resource.data.inviteCode is string
          && (request.resource.data.expiresAt == null || request.resource.data.expiresAt is string);
        allow update: if isPresidentsClub(crewId)
          && docId == 'settings'
          && canManageCrewSettings(crewId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'inviteCode',
            'expiresAt',
            'updatedAt'
          ])
          && request.resource.data.inviteCode is string
          && (request.resource.data.expiresAt == null || request.resource.data.expiresAt is string);
        allow delete: if false;
      }

      match /announcements/{announcementId} {
        allow read: if canReadCrewData(crewId);
        allow create, delete: if isPresidentsClub(crewId)
          && canUseDelegatedTool(crewId, 'manageAnnouncements');
        allow update: if isPresidentsClub(crewId)
          && (
            canUseDelegatedTool(crewId, 'manageAnnouncements')
            || (
              isCrewMember(crewId)
              && request.resource.data.diff(resource.data).changedKeys().hasOnly(['likedBy'])
            )
          );
      }

      match /rides/{rideId} {
        allow read: if canReadCrewData(crewId);
        allow create, delete: if isPresidentsClub(crewId)
          && canUseDelegatedTool(crewId, 'manageRides');
        allow update: if isPresidentsClub(crewId)
          && (
            canUseDelegatedTool(crewId, 'manageRides')
            || (
              isCrewMember(crewId)
              && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'attendees',
                'checkedIn',
                'photos'
              ])
            )
          );
      }

      match /albums/{albumId} {
        allow read: if canReadCrewData(crewId);
        allow create, delete: if isPresidentsClub(crewId)
          && canUseDelegatedTool(crewId, 'manageAlbums');
        allow update: if isPresidentsClub(crewId)
          && (
            canUseDelegatedTool(crewId, 'manageAlbums')
            || (
              isCrewMember(crewId)
              && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'photos',
                'updatedAt'
              ])
            )
          );
      }

      match /joinRequests/{requestId} {
        allow read: if isPresidentsClub(crewId)
          && (
            (signedIn() && requestId == request.auth.uid) ||
            isDeveloperAdminEmail() ||
            isCrewLeader(crewId) ||
            memberPermission(crewId, 'manageJoinRequests')
          );
        allow create: if isPresidentsClub(crewId)
          && signedIn()
          && request.resource.data.id == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.crewId == crewId
          && request.resource.data.status == 'pending'
          && !isCrewMember(crewId);
        allow update: if isPresidentsClub(crewId)
          && (
            (
              signedIn()
              && requestId == request.auth.uid
              && resource.data.status == 'denied'
              && request.resource.data.id == request.auth.uid
              && request.resource.data.userId == request.auth.uid
              && request.resource.data.crewId == crewId
              && request.resource.data.status == 'pending'
              && !isCrewMember(crewId)
            )
            || (
              canManageJoinRequestsForPresidentsClub()
              && request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'status',
                'decidedAt',
                'decidedBy'
              ])
              && ['approved', 'denied'].hasAny([request.resource.data.status])
              && request.resource.data.decidedBy == request.auth.uid
            )
          );
        allow delete: if false;
      }

      match /statsHistory/{snapshotId} {
        allow read: if canReadCrewData(crewId);
        allow create, update, delete: if false;
      }
    }

    match /crewInviteCodes/{inviteCode} {
      allow read: if canManageCrewSettings('presidents-mc');
      allow create: if signedIn()
        && request.resource.data.code == inviteCode
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.crewId == 'presidents-mc'
        && (request.resource.data.expiresAt == null || request.resource.data.expiresAt is string)
        && exists(crewPath('presidents-mc'))
        && canManageCrewSettings('presidents-mc');
      allow update: if signedIn()
        && request.resource.data.code == inviteCode
        && request.resource.data.crewId == 'presidents-mc'
        && (request.resource.data.expiresAt == null || request.resource.data.expiresAt is string)
        && canManageCrewSettings('presidents-mc');
      allow delete: if canManageCrewSettings('presidents-mc');
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
