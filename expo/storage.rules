rules_version = '2';

// NOTE on the design of these rules:
// Cloud Storage cross-service rules (`firestore.get` / `firestore.exists`) are
// only reliable against the *default* Firestore database, and impose a hard
// 2-document-lookup limit per evaluation. This project uses a *named* Firestore
// database ("default", not "(default)"), so cross-service lookups here did NOT
// resolve — every firestore-dependent rule (including the `read` rules that
// `getDownloadURL` needs) denied access, surfacing as `storage/unauthorized`
// even for legitimate admins/members.
//
// Storage rules are therefore intentionally self-contained: they only check
// auth + path scoping + image content. Firestore Security Rules
// (firestore.rules) remain the real business-permission gate — e.g. only
// admins/officers can create announcement/ride/album documents, members cannot.
// A stored image is useless without the corresponding Firestore document that
// references it, which Firestore rules already protect.

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    // Accept the upload when it is a reasonably sized image. The content type is
    // treated as optional: some React Native blob/upload paths omit it or send
    // application/octet-stream, and the client always writes the file to an
    // image-typed path anyway. Denying on a missing content type was a source of
    // spurious upload failures.
    function isImageUpload() {
      return request.resource != null
        && request.resource.size < 15 * 1024 * 1024
        && (
          request.resource.contentType == null
          || request.resource.contentType.matches('image/.*')
        );
    }

    match /users/{userId}/avatar.jpg {
      allow read, write: if isSelf(userId);
    }

    match /users/{userId}/avatars/{fileName} {
      allow read, write: if isSelf(userId);
    }

    match /crews/{crewId}/logo.jpg {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUpload();
    }

    match /crews/{crewId}/announcements/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUpload();
    }

    match /crews/{crewId}/announcements/{announcementId}/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUpload();
    }

    match /crews/{crewId}/rides/{rideId}/cover.jpg {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUpload();
    }

    match /crews/{crewId}/rides/{rideId}/photos/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUpload();
    }

    match /crews/{crewId}/albums/{albumId}/cover.jpg {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUpload();
    }

    match /crews/{crewId}/albums/{albumId}/photos/{fileName} {
      allow read: if signedIn();
      allow write: if signedIn() && isImageUpload();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
