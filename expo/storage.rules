rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function crewDoc(crewId) {
      return firestore.get(/databases/default/documents/crews/$(crewId));
    }

    function crewMemberDoc(crewId, userId) {
      return firestore.get(/databases/default/documents/crews/$(crewId)/members/$(userId));
    }

    function userDoc(userId) {
      return firestore.get(/databases/default/documents/users/$(userId));
    }

    function isCrewMember(crewId) {
      return signedIn()
        && firestore.exists(/databases/default/documents/crews/$(crewId)/members/$(request.auth.uid));
    }

    function isCrewUser(crewId) {
      return signedIn()
        && firestore.exists(/databases/default/documents/users/$(request.auth.uid))
        && userDoc(request.auth.uid).data.crewId == crewId;
    }

    function isCrewParticipant(crewId) {
      return isCrewMember(crewId) || isCrewUser(crewId);
    }

    function isCrewOwner(crewId) {
      return isCrewParticipant(crewId) && crewDoc(crewId).data.ownerId == request.auth.uid;
    }

    function isCrewLeader(crewId) {
      return (
        isCrewMember(crewId)
        && ['admin', 'officer'].hasAny([crewMemberDoc(crewId, request.auth.uid).data.role])
      ) || (
        isCrewUser(crewId)
        && ['admin', 'officer'].hasAny([userDoc(request.auth.uid).data.role])
      );
    }

    function isDeveloperSupport(crewId) {
      return isCrewMember(crewId)
        && crewMemberDoc(crewId, request.auth.uid).data.isDeveloperSupport == true;
    }

    function hasCrewPermission(crewId, permission) {
      return isCrewMember(crewId)
        && crewMemberDoc(crewId, request.auth.uid).data.permissions[permission] == true;
    }

    function canManageAnnouncements(crewId) {
      return isDeveloperSupport(crewId) || isCrewLeader(crewId) || hasCrewPermission(crewId, 'manageAnnouncements');
    }

    function canManageRides(crewId) {
      return isDeveloperSupport(crewId) || isCrewLeader(crewId) || hasCrewPermission(crewId, 'manageRides');
    }

    function canManageAlbums(crewId) {
      return isDeveloperSupport(crewId) || isCrewLeader(crewId) || hasCrewPermission(crewId, 'manageAlbums');
    }

    function hasActiveSubscription(crewId) {
      let ownerId = crewDoc(crewId).data.subscriptionOwnerId;
      return ownerId is string
        && ['active', 'trialing'].hasAny([crewDoc(crewId).data.subscriptionStatus])
        && firestore.exists(/databases/default/documents/crews/$(crewId)/members/$(ownerId))
        && crewMemberDoc(crewId, ownerId).data.isDeveloperSupport != true;
    }

    function hasPaidFeatureAccess(crewId) {
      return isDeveloperSupport(crewId) || hasActiveSubscription(crewId);
    }

    function announcementDoc(crewId, announcementId) {
      return firestore.get(/databases/default/documents/crews/$(crewId)/announcements/$(announcementId));
    }

    function canWriteAnnouncementImage(crewId, announcementId) {
      return canManageAnnouncements(crewId)
        || (
          isCrewMember(crewId)
          && firestore.exists(/databases/default/documents/crews/$(crewId)/announcements/$(announcementId))
          && announcementDoc(crewId, announcementId).data.authorId == request.auth.uid
        );
    }

    match /users/{userId}/avatar.jpg {
      allow read, write: if isSelf(userId);
    }

    match /users/{userId}/avatars/{fileName} {
      allow read, write: if isSelf(userId);
    }

    match /crews/{crewId}/logo.jpg {
      allow read: if isCrewParticipant(crewId);
      allow write: if isCrewOwner(crewId) && crewDoc(crewId).data.status == 'active';
    }

    match /crews/{crewId}/announcements/{fileName} {
      allow read: if isCrewParticipant(crewId);
      allow write: if isCrewParticipant(crewId);
    }

    match /crews/{crewId}/announcements/{announcementId}/{fileName} {
      allow read: if isCrewParticipant(crewId);
      allow write: if canWriteAnnouncementImage(crewId, announcementId);
    }

    match /crews/{crewId}/rides/{rideId}/cover.jpg {
      allow read: if isCrewParticipant(crewId);
      allow write: if canManageRides(crewId) && hasPaidFeatureAccess(crewId);
    }

    match /crews/{crewId}/rides/{rideId}/photos/{fileName} {
      allow read: if isCrewParticipant(crewId);
      allow write: if isCrewParticipant(crewId) && hasPaidFeatureAccess(crewId);
    }

    match /crews/{crewId}/albums/{albumId}/cover.jpg {
      allow read: if isCrewParticipant(crewId);
      allow write: if canManageAlbums(crewId) && hasPaidFeatureAccess(crewId);
    }

    match /crews/{crewId}/albums/{albumId}/photos/{fileName} {
      allow read: if isCrewParticipant(crewId);
      allow write: if isCrewParticipant(crewId) && hasPaidFeatureAccess(crewId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
