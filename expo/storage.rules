rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function crewDoc(crewId) {
      return firestore.get(/databases/(default)/documents/crews/$(crewId));
    }

    function crewMemberDoc(crewId, userId) {
      return firestore.get(/databases/(default)/documents/crews/$(crewId)/members/$(userId));
    }

    function isCrewMember(crewId) {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/crews/$(crewId)/members/$(request.auth.uid));
    }

    function isCrewOwner(crewId) {
      return isCrewMember(crewId) && crewDoc(crewId).data.ownerId == request.auth.uid;
    }

    function isCrewLeader(crewId) {
      return isCrewMember(crewId)
        && ['admin', 'officer'].hasAny([crewMemberDoc(crewId, request.auth.uid).data.role]);
    }

    function hasCrewPermission(crewId, permission) {
      return isCrewMember(crewId)
        && crewMemberDoc(crewId, request.auth.uid).data.permissions[permission] == true;
    }

    function canManageAnnouncements(crewId) {
      return isCrewLeader(crewId) || hasCrewPermission(crewId, 'manageAnnouncements');
    }

    function canManageRides(crewId) {
      return isCrewLeader(crewId) || hasCrewPermission(crewId, 'manageRides');
    }

    function canManageAlbums(crewId) {
      return isCrewLeader(crewId) || hasCrewPermission(crewId, 'manageAlbums');
    }

    function hasActiveSubscription(crewId) {
      let ownerId = crewDoc(crewId).data.subscriptionOwnerId;
      return ownerId is string
        && ['active', 'trialing'].hasAny([crewDoc(crewId).data.subscriptionStatus])
        && firestore.exists(/databases/(default)/documents/crews/$(crewId)/members/$(ownerId))
        && crewMemberDoc(crewId, ownerId).data.isDeveloperSupport != true;
    }

    match /users/{userId}/avatar.jpg {
      allow read, write: if isSelf(userId);
    }

    match /users/{userId}/avatars/{fileName} {
      allow read, write: if isSelf(userId);
    }

    match /crews/{crewId}/logo.jpg {
      allow read: if isCrewMember(crewId);
      allow write: if isCrewOwner(crewId) && crewDoc(crewId).data.status == 'active';
    }

    match /crews/{crewId}/announcements/{fileName} {
      allow read: if isCrewMember(crewId);
      allow write: if canManageAnnouncements(crewId);
    }

    match /crews/{crewId}/rides/{rideId}/cover.jpg {
      allow read: if isCrewMember(crewId);
      allow write: if canManageRides(crewId) && hasActiveSubscription(crewId);
    }

    match /crews/{crewId}/rides/{rideId}/photos/{fileName} {
      allow read: if isCrewMember(crewId);
      allow write: if isCrewMember(crewId) && hasActiveSubscription(crewId);
    }

    match /crews/{crewId}/albums/{albumId}/cover.jpg {
      allow read: if isCrewMember(crewId);
      allow write: if canManageAlbums(crewId) && hasActiveSubscription(crewId);
    }

    match /crews/{crewId}/albums/{albumId}/photos/{fileName} {
      allow read: if isCrewMember(crewId);
      allow write: if isCrewMember(crewId) && hasActiveSubscription(crewId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
