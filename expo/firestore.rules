rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function crewPath(crewId) {
      return /databases/$(database)/documents/crews/$(crewId);
    }

    function memberPath(crewId, userId) {
      return /databases/$(database)/documents/crews/$(crewId)/members/$(userId);
    }

    function userPath(userId) {
      return /databases/$(database)/documents/users/$(userId);
    }

    function crewDoc(crewId) {
      return get(crewPath(crewId));
    }

    function isCrewMember(crewId) {
      return signedIn() && exists(memberPath(crewId, request.auth.uid));
    }

    function isCrewUser(crewId) {
      return signedIn()
        && exists(userPath(request.auth.uid))
        && get(userPath(request.auth.uid)).data.crewId == crewId;
    }

    function isCrewParticipant(crewId) {
      return isCrewMember(crewId) || isCrewUser(crewId);
    }

    function isCrewOwner(crewId) {
      return isCrewParticipant(crewId) && crewDoc(crewId).data.ownerId == request.auth.uid;
    }

    function isCrewLeader(crewId) {
      return (
        isCrewMember(crewId)
        && (
          get(memberPath(crewId, request.auth.uid)).data.role == 'admin'
          || get(memberPath(crewId, request.auth.uid)).data.role == 'officer'
        )
      ) || (
        isCrewUser(crewId)
        && (
          get(userPath(request.auth.uid)).data.role == 'admin'
          || get(userPath(request.auth.uid)).data.role == 'officer'
        )
      );
    }

    function isDeveloperSupport(crewId) {
      return isCrewMember(crewId)
        && get(memberPath(crewId, request.auth.uid)).data.isDeveloperSupport == true;
    }

    function hasCrewPermission(crewId, permission) {
      return isCrewMember(crewId)
        && get(memberPath(crewId, request.auth.uid)).data.permissions[permission] == true;
    }

    function canManageAnnouncements(crewId) {
      return isDeveloperSupport(crewId) || isCrewLeader(crewId) || hasCrewPermission(crewId, 'manageAnnouncements');
    }

    function canManageRides(crewId) {
      return isDeveloperSupport(crewId) || isCrewLeader(crewId) || hasCrewPermission(crewId, 'manageRides');
    }

    function canManageAlbums(crewId) {
      return isDeveloperSupport(crewId) || isCrewLeader(crewId) || hasCrewPermission(crewId, 'manageAlbums');
    }

    function canManageJoinRequests(crewId) {
      return isDeveloperSupport(crewId) || isCrewLeader(crewId) || hasCrewPermission(crewId, 'manageJoinRequests');
    }

    function hasActiveSubscription(crewId) {
      return crewDoc(crewId).data.subscriptionOwnerId is string
        && ['active', 'trialing'].hasAny([crewDoc(crewId).data.subscriptionStatus]);
    }

    function hasPaidFeatureAccess(crewId) {
      // Mirror the client (CrewProvider): a club only needs an active subscription
      // when billingRequired == true. If billing isn't required (field false or
      // unset), paid features are open. This keeps client and rules in lockstep so
      // the app never lets a write through that the rules then deny.
      return isDeveloperSupport(crewId)
        || crewDoc(crewId).data.billingRequired != true
        || hasActiveSubscription(crewId);
    }

    function isSubscriptionActivation(crewId) {
      return isCrewLeader(crewId)
        && get(memberPath(crewId, request.auth.uid)).data.isDeveloperSupport != true
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'billingRequired',
          'subscriptionOwnerId',
          'subscriptionStatus'
        ])
        && request.resource.data.billingRequired == true
        && request.resource.data.subscriptionOwnerId == request.auth.uid
        && ['active', 'trialing'].hasAny([request.resource.data.subscriptionStatus]);
    }

    function validSelfCrewState(data) {
      return data.crewId == null
        ? data.role == 'member'
        : exists(memberPath(data.crewId, request.auth.uid))
          && get(memberPath(data.crewId, request.auth.uid)).data.role == data.role;
    }

    match /users/{userId} {
      allow read: if isSelf(userId);
      allow create: if isSelf(userId)
        && request.resource.data.id == userId
        && request.resource.data.role == 'member'
        && request.resource.data.crewId == null;
      allow update: if isSelf(userId)
        && request.resource.data.id == userId
        && validSelfCrewState(request.resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          'name',
          'avatar',
          'bike',
          'bikes',
          'preferences',
          'hasOnboarded',
          'hasFeatureOnboarded',
          'lastActiveAt',
          'crewId',
          'role',
          'pendingCrewId'
        ]);
      allow delete: if isSelf(userId);

      match /pushTokens/{token} {
        allow read, create, update, delete: if isSelf(userId);
      }
    }

    match /crews/{crewId} {
      allow read: if isCrewParticipant(crewId)
        || (resource.data.isDiscoverable == true && resource.data.status == 'active');
      allow create: if signedIn()
        && request.resource.data.id == crewId
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.memberCount == 1
        && request.resource.data.status == 'active'
        && request.resource.data.archivedAt == null
        && request.resource.data.purgeAt == null
        && (
          request.resource.data.subscriptionOwnerId == null
          || request.resource.data.subscriptionOwnerId == request.auth.uid
        );
      allow update: if (
          isCrewOwner(crewId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'name',
            'description',
            'logoUrl',
            'isDiscoverable',
            'requiresApproval',
            'nameLower'
          ])
        ) || isSubscriptionActivation(crewId);
      allow delete: if false;

      match /members/{memberId} {
        allow read: if isCrewParticipant(crewId);
        allow create: if isSelf(memberId)
          && crewDoc(crewId).data.ownerId == request.auth.uid
          && request.resource.data.id == request.auth.uid
          && request.resource.data.role == 'admin';
        allow update: if isSelf(memberId)
          && isCrewMember(crewId)
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'name',
            'avatar',
            'bike',
            'bikes'
          ]);
        allow delete: if false;
      }

      match /private/{docId} {
        allow read: if false;
        allow create: if isCrewLeader(crewId)
          && docId == 'settings'
          && request.resource.data.keys().hasOnly([
            'inviteCode',
            'expiresAt',
            'updatedAt'
          ])
          && request.resource.data.inviteCode is string;
        allow update: if isCrewLeader(crewId)
          && docId == 'settings'
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'inviteCode',
            'expiresAt',
            'updatedAt'
          ])
          && request.resource.data.inviteCode is string;
        allow delete: if false;
      }

      match /announcements/{announcementId} {
        allow read: if isCrewParticipant(crewId);
        allow create, delete: if canManageAnnouncements(crewId);
        // Any crew participant may like/unlike; everything else is leader-only.
        allow update: if canManageAnnouncements(crewId)
          || (isCrewParticipant(crewId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly(['likedBy']));
      }

      match /rides/{rideId} {
        allow read: if isCrewParticipant(crewId);
        allow create, delete: if canManageRides(crewId);
        // RSVP + check-in are core safety features and stay available even
        // when the club's subscription lapses; only photo posting is paid.
        allow update: if canManageRides(crewId)
          || (isCrewParticipant(crewId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'attendees',
              'checkedIn'
            ]))
          || (isCrewParticipant(crewId) && hasPaidFeatureAccess(crewId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'attendees',
              'checkedIn',
              'photos'
            ]));

        // Ride chat doubles as the safety check-in channel, so it is not
        // gated on the club subscription either.
        match /messages/{messageId} {
          allow read: if isCrewParticipant(crewId);
          allow create: if isCrewParticipant(crewId)
            && request.resource.data.userId == request.auth.uid
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() <= 1000
            && (
              request.resource.data.type == 'chat'
              || (
                request.resource.data.type == 'status'
                && get(/databases/$(database)/documents/crews/$(crewId)/rides/$(rideId)).data.attendees.hasAny([request.auth.uid])
              )
            );
          allow update: if false;
          allow delete: if isSelf(resource.data.userId) || canManageRides(crewId);
        }
      }

      match /albums/{albumId} {
        allow read: if isCrewParticipant(crewId);
        allow create, delete: if canManageAlbums(crewId);
        allow update: if canManageAlbums(crewId)
          || (isCrewParticipant(crewId) && hasPaidFeatureAccess(crewId)
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              'photos',
              'updatedAt'
            ]));
      }

      match /joinRequests/{requestId} {
        allow read: if (signedIn() && requestId == request.auth.uid) || canManageJoinRequests(crewId);
        allow create: if signedIn()
          && request.resource.data.id == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.crewId == crewId
          && request.resource.data.status == 'pending'
          && !isCrewMember(crewId);
        // A denied requester may resubmit: flip their own request back to
        // pending. Everything else stays immutable to non-admins.
        allow update: if signedIn()
          && requestId == request.auth.uid
          && resource.data.status == 'denied'
          && request.resource.data.id == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.crewId == crewId
          && request.resource.data.status == 'pending'
          && !isCrewMember(crewId);
        allow delete: if signedIn() && requestId == request.auth.uid && resource.data.status == 'pending';
      }

      match /statsHistory/{snapshotId} {
        allow read: if isCrewMember(crewId);
        allow create, update, delete: if false;
      }
    }

    match /crewInviteCodes/{inviteCode} {
      allow read, delete: if false;
      allow create: if signedIn()
        && request.resource.data.code == inviteCode
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.crewId is string
        && exists(crewPath(request.resource.data.crewId))
        && isCrewLeader(request.resource.data.crewId);
      allow update: if signedIn()
        && request.resource.data.code == inviteCode
        && request.resource.data.crewId is string
        && resource.data.crewId == request.resource.data.crewId
        && isCrewLeader(request.resource.data.crewId);
    }
  }
}
